{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build current project (ImGui + OpenGL)",
            "command": "C:/mingw64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "-Wno-register",
                "-DGLEW_STATIC",
                "-I${workspaceFolder}/projects/solar-system-simulator/include",
                "-Ic:/glfw-3.4/include",
                "-Ic:/glew-2.3.1/include",
                "-Ic:/glm-0.9.3.2",
                "-L${workspaceFolder}/projects/solar-system-simulator/lib",
                "-Lc:/glfw-3.4/lib-mingw-w64",
                "${workspaceFolder}/projects/solar-system-simulator/src/main.cpp",
                "-x",
                "c",
                "c:/glew-2.3.1/src/glew.c",
                "-lglfw3dll",
                "-lopengl32",
                "-lglu32",
                "-lgdi32",
                "-luser32",
                "-lshell32",
                "-mconsole",
                "-o",
                "${workspaceFolder}/projects/solar-system-simulator/bin/main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}/projects/solar-system-simulator"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: C:/mingw64/bin/g++.exe"
        }
    ]
}